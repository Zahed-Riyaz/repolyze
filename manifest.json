{
  "manifest_version": 3,
  "name": "GitHub Repo Analyzer & RAG Chat",
  "version": "1.1",
  "description": "Analyze GitHub repos: issues, tech stack, maintainers, contributor health, and RAG-powered Chat.",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://api.github.com/*",
    "https://github.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://api.groq.com/*",
    "http://localhost:11434/*"
  ],
  "action": {
    "default_title": "Open Repo Analyzer"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ]
}
